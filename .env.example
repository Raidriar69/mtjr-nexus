# =============================================================
# MTJR Nexus — Environment Variables
# Copy this file to .env.local and fill in all values.
# NEVER commit .env.local to source control.
# =============================================================

# ─── App ──────────────────────────────────────────────────────
NEXTAUTH_URL=https://mtjrnexus.com
NEXTAUTH_SECRET=your-32-char-random-secret-here

# ─── MongoDB Atlas ────────────────────────────────────────────
# Get from Atlas → Connect → Drivers
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/mtjrnexus?retryWrites=true&w=majority

# ─── Email (Nodemailer) ───────────────────────────────────────
# Gmail: enable 2FA, create an App Password at myaccount.google.com/apppasswords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM=MTJR Nexus <your@gmail.com>

# ─── Stripe ───────────────────────────────────────────────────
# Test keys: https://dashboard.stripe.com/test/apikeys
# Live keys: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# ─── PayPal ───────────────────────────────────────────────────
# Create an app at https://developer.paypal.com/developer/applications
# Set PAYPAL_ENV=live for production, sandbox for testing
PAYPAL_ENV=live
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_SECRET=your-paypal-secret
NEXT_PUBLIC_PAYPAL_CLIENT_ID=your-paypal-client-id

# ─── NOWPayments (Crypto) ─────────────────────────────────────
# Sign up at https://nowpayments.io
# API key from: Dashboard → Store Settings → API Keys
# IPN secret from: Dashboard → Store Settings → IPN Secret Key
NOWPAYMENTS_API_KEY=your-nowpayments-api-key
NOWPAYMENTS_IPN_SECRET=your-nowpayments-ipn-secret
